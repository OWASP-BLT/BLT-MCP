{
  "mcpServers": {
    "blt-mcp-python": {
      "command": "uv",
      "args": [
        "--directory", 
        ".", 
        "run", 
        "python", 
        "main.py"
      ],
      "env": {
        "BLT_API_BASE": "https://blt.owasp.org/api",
        "BLT_API_KEY": "your_api_key_here"
      }
    }
  }
}
